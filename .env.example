# ============================================================================
# PostgreSQL Configuration (docker-compose environment)
# ============================================================================
POSTGRES_USER=mobidf
POSTGRES_PASSWORD=mobidf_secret
POSTGRES_DB=mobidf
POSTGRES_PORT=5432

# ============================================================================
# Backend Configuration
# ============================================================================
BACKEND_PORT=8000
DEBUG=false
SECRET_KEY=change_me_in_production

# CORS Origins - allow localhost for development, add production domain as needed
# Development: http://localhost:3000
# Production: https://mobidf.brocode.net.br
CORS_ORIGINS=http://localhost:3000,https://mobidf.brocode.net.br

# ETL / External APIs
GTFS_DF_URL=https://www.dados.df.gov.br/dataset/gtfs-df/resource/gtfs-df.zip
GTFS_RT_URL=https://www.semob.df.gov.br/gtfs-rt/vehicle-positions
IBGE_API_URL=https://servicodados.ibge.gov.br/api/v3
GOOGLE_MAPS_API_KEY=

# ============================================================================
# Frontend Configuration
# ============================================================================
FRONTEND_PORT=3000
NODE_ENV=production

# API URL - for local development use localhost, for production use reverse proxy URL
# Development: http://localhost:8000
# Production via nginx: https://mobidf.brocode.net.br/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# Map tiles (OpenStreetMap)
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ============================================================================
# Production Deployment - with Nginx Reverse Proxy
# ============================================================================
# When running with infra/docker-compose.prod.yml, update:
# 
# NEXT_PUBLIC_API_URL=https://mobidf.brocode.net.br/api
# CORS_ORIGINS=https://mobidf.brocode.net.br
# 
# Then:
# docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# ============================================================================
# Docker Build Arguments (for GitHub Actions / CI)
# ============================================================================
# BUILD_DATE: Auto-generated in docker-compose.yml if not provided
# VCS_REF: Git commit SHA (set by CI/CD)
# VERSION: Release version (set by CI/CD)

# BUILD_DATE=2026-06-21T12:00:00Z
# VCS_REF=abc1234def5678
# VERSION=1.0.0
